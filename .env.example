# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=   # bcrypt hash of your password (generate with: node -e "const b=require('bcryptjs'); b.hash('yourpass',10).then(console.log)")
ADMIN_PASSWORD=admin   # Plain fallback if ADMIN_PASSWORD_HASH is empty (dev only)

# JWT
JWT_SECRET=            # 32+ char random string (generate with: openssl rand -hex 32)
JWT_EXPIRES_IN=24h

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Ports
BACKEND_PORT=3001
FRONTEND_PORT=3000

# Environment
NODE_ENV=production

# Frontend public URL (for browser-side API calls — must be accessible from browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
